# Copy this file to .env and fill in real values. Never commit the real .env file.

# --- App / environment ---
ENVIRONMENT=dev                # dev | prod
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR

# --- LLM (DeepSeek, OpenAI-compatible chat completions) ---
DEEPSEEK_API_KEY=your_deepseek_api_key   #sk-aa4b6de8a6264699b704d71f5db78fac
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3

# --- Database ---
# SQLite for MVP. Swap to a Postgres URL later without touching business logic,
# e.g. postgresql+psycopg2://user:password@host:5432/geo
DATABASE_URL=sqlite:///./geo.db

# --- Vector store / embeddings ---
# Local, persistent ChromaDB storage directory.
CHROMA_PERSIST_DIR=./chroma
# Local, free embedding model only. Never point this at a paid embeddings API.
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5

# --- Auth (JWT) ---
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRY_MINUTES=1440         # 24 hours

# --- Scheduler (weekly full audit) ---
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_DAYS=7
